; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Shadows_of_the_Andes"
run/main_scene="res://Scenes/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

TransitionManager="*res://Scripts/Systems/TransitionManager.gd"
MessageLog="*res://Scripts/Systems/MessageLog.gd"
AudioManager="*res://Scripts/Systems/AudioManager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=400
window/size/window_width_override=1920
window/size/window_height_override=1200
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/stretch/scale_mode="integer"

[gui]

theme/default_font_antialiasing=0

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
textures/size/window_height_override=1200
rendering/2d/snap/snap_2d_to_pixel=true
rendering/2d/snap/snap_2d_vertices_to_pixel=true
text_server/data_path="res://Fonts"
gui/theme/default_font_antialiased=false

[window]

window/size/viewport_width=1920
window/size/viewport_height=1080
